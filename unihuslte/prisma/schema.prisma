// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// University model for storing Nigerian universities
model University {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  createdAt DateTime @default(now())
  
  // Relations
  users     User[]
  
  @@map("universities")
}

// User model for student accounts
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  fullName     String
  universityId String
  otpToken     String?
  otpExpiry    DateTime?
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  university   University @relation(fields: [universityId], references: [id])
  listings     Listing[]
  
  @@map("users")
}

// Listing model for marketplace items/services
model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  tags        String?  // Comma-separated tags
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("listings")
}
